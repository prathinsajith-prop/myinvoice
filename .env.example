# =============================================================================
# myInvoice.ae — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# PostgreSQL 18+ recommended for best performance.
# Local dev: Use docker-compose to run PostgreSQL 18 locally (see docker-compose.yml).
# Production: Supabase (supabase.com) or Neon (neon.tech) for managed Postgres.
# For Prisma migrations, use DIRECT_URL (non-pooled connection).
# For app: DATABASE_URL can be pooled (PgBouncer via Supabase, or local).
# For local dev: Both can point to localhost without pooling.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://myinvoice:password@localhost:5432/myinvoice_dev?sslmode=disable"
DIRECT_URL="postgresql://myinvoice:password@localhost:5432/myinvoice_dev?sslmode=disable"

# REDIS (Rate Limiting & Caching)
# Local dev: redis://localhost:6379 (run via `docker-compose up` for Docker Compose setup).
# Production: Use DigitalOcean Managed Databases (Redis), AWS ElastiCache, or self-hosted Redis.
# Without this set, falls back to in-memory rate limiter (dev only, single-instance only).
# If self-hosting Redis, use AUTH with strong password: redis://:PASSWORD@HOST:PORT
# For cluster mode, use: redis+cluster://HOST1:PORT1,HOST2:PORT2,...
# For Sentinel, use: redis-sentinel://HOST1:PORT1,HOST2:PORT2/.../MASTER_NAME
# ---
# Example with password: redis://:your-secure-password@localhost:6379
# Example production (DigitalOcean): redis://default:PASSWORD@HOST:PORT
# Example production (AWS ElastiCache): redis://HOST.cache.amazonaws.com:6379
# Example production (Upstash REST, if preferred): Set to local Redis URL — REST API not supported here.
# If Redis is unreachable, the app will use in-memory rate limiting (warning logged).
# This ensures the app stays up even if Redis is temporarily down.
# But for production, ensure Redis is always available (use monitoring + alerting).
# For cluster/Sentinel setups, add dependencies: pnpm add redis-sentinel
# ---
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# AUTHENTICATION (NextAuth v5)
# Generate a secret: openssl rand -base64 32
# Both AUTH_SECRET and NEXTAUTH_SECRET must be set and identical.
# -----------------------------------------------------------------------------
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="same-value-as-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (optional — enables "Sign in with Google")
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# EMAIL
# Provider: "resend" (recommended) or "gmail"
# Resend API key: https://resend.com/api-keys
# Gmail: use an App Password (requires 2FA on the Google account)
# EMAIL_DEV_FALLBACK=true → logs emails to console in dev (no API key needed)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM="noreply@myinvoice.ae"
EMAIL_DEV_FALLBACK="false"

# -----------------------------------------------------------------------------
# STRIPE (payment processing)
# Keys from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# Test mode keys start with sk_test_ and pk_test_
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# CRON JOBS (Vercel Cron authentication)
# Generate: openssl rand -hex 32
# Set the same value in Vercel's Environment Variables dashboard.
# -----------------------------------------------------------------------------
CRON_SECRET="generate-with-openssl-rand-hex-32"

# -----------------------------------------------------------------------------
# ERROR MONITORING — Sentry (https://sentry.io)
# Sentry provides real-time error tracking, performance monitoring, and alerting.
# Setup:
#   1. Create a free account at https://sentry.io
#   2. Create a new project with "Next.js" platform
#   3. Copy the DSN (Data Source Name) from project settings
#   4. Set SENTRY_DSN below + NEXT_PUBLIC_SENTRY_DSN to the same value
#   5. Optional: Set SENTRY_ORG and SENTRY_PROJECT for source maps upload
# Usage:
#   - Errors in API routes are automatically captured
#   - Client-side errors are captured and reported
#   - Performance metrics (Core Web Vitals) are tracked
#   - User sessions with errors are replayed (Session Replay)
# In development (NODE_ENV=development):
#   - All errors logged to console + Sentry (debug=true)
#   - 100% sample rate for traces (see sentry.client.config.ts)
# In production:
#   - Only errors sent to Sentry (filtered by beforeSend hooks)
#   - 10% sample rate for performance traces (reduces quota usage)
#   - Full stack traces + source maps for debugging
# Sentry auth token (for automatic source maps upload to Vercel):
#   1. Generate at: https://sentry.io/settings/account/api/auth-tokens/
#   2. Choose "Release & health" scope
# Without these variables, error tracking is disabled (errors logged to console only).
SENTRY_DSN="https://your-key@sentry.io/your-project-id"
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_SENTRY_DSN="https://your-key@sentry.io/your-project-id"

# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# FILE STORAGE — AWS S3
# Used for organization logos, user avatars, invoice attachments, PDF exports.
# Create a bucket at: https://s3.console.aws.amazon.com
# Create IAM credentials with s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket.
# For public reads, attach a bucket policy allowing s3:GetObject for "*".
# Without these set, the app stores images as base64 in the database (dev only).
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="me-south-1"
AWS_S3_BUCKET="myinvoice-assets"
AWS_S3_PUBLIC_URL="https://myinvoice-assets.s3.me-south-1.amazonaws.com"
