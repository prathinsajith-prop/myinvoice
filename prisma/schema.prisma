// =============================================================================
// TENANT: RECURRING INVOICES
// =============================================================================

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

model RecurringInvoice {
  id             String @id @default(cuid())
  organizationId String

  customerId String
  templateName String?

  frequency       RecurringFrequency @default(MONTHLY)
  startDate       DateTime
  endDate         DateTime?
  nextRunDate     DateTime
  lastRunDate     DateTime?
  occurrencesLeft Int?

  invoiceType   String  @default("TAX_INVOICE")
  currency      String  @default("AED")
  exchangeRate  Decimal @default(1) @db.Decimal(10, 6)
  notes         String?
  terms         String?

  subtotal  Decimal @default(0) @db.Decimal(15, 2)
  totalVat  Decimal @default(0) @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(15, 2)
  total     Decimal @default(0) @db.Decimal(15, 2)

  autoSend  Boolean @default(false)
  status    RecurringStatus @default(ACTIVE)

  invoicesGenerated Int @default(0)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id])
  lineItems    RecurringInvoiceLineItem[]
  generatedInvoices Invoice[] @relation("RecurringSource")

  @@index([organizationId, status])
  @@index([organizationId, nextRunDate])
  @@index([customerId])
  @@index([organizationId, deletedAt, status])
  @@index([organizationId, deletedAt, createdAt])
}

model RecurringInvoiceLineItem {
  id                 String @id @default(cuid())
  recurringInvoiceId String

  productId     String?
  description   String
  quantity      Decimal @db.Decimal(12, 3)
  unitPrice     Decimal @db.Decimal(12, 2)
  unitOfMeasure String  @default("unit")
  discount      Decimal @default(0) @db.Decimal(5, 2)
  vatTreatment  String  @default("STANDARD_RATED")
  vatRate       Decimal @default(5) @db.Decimal(5, 2)
  sortOrder     Int     @default(0)

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  product          Product?         @relation(fields: [productId], references: [id])

  @@index([recurringInvoiceId])
}

// =============================================================================
// TENANT: PAYMENT REMINDERS
// =============================================================================

enum ReminderType {
  BEFORE_DUE
  ON_DUE
  AFTER_DUE
}

enum ReminderChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model PaymentReminder {
  id             String @id @default(cuid())
  organizationId String

  invoiceId String
  channel   ReminderChannel @default(EMAIL)
  type      ReminderType
  status    ReminderStatus  @default(PENDING)

  scheduledAt DateTime
  sentAt      DateTime?
  failReason  String?

  subject   String?
  body      String?
  recipient String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([organizationId, status])
  @@index([invoiceId])
  @@index([scheduledAt, status])
}

// =============================================================================
// PURCHASE ORDERS
// =============================================================================

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String @id @default(cuid())
  organizationId String
  supplierId     String

  poNumber    String
  reference   String?
  description String?

  issueDate    DateTime  @default(now())
  expectedDate DateTime?

  status PurchaseOrderStatus @default(DRAFT)

  currency     String  @default("AED")
  exchangeRate Decimal @default(1) @db.Decimal(10, 6)

  subtotal Decimal @db.Decimal(15, 2)
  totalVat Decimal @db.Decimal(15, 2)
  discount Decimal @default(0) @db.Decimal(15, 2)
  total    Decimal @db.Decimal(15, 2)

  notes           String?
  terms           String?
  internalNotes   String?
  shippingAddress String?

  sentAt      DateTime?
  confirmedAt DateTime?
  receivedAt  DateTime?

  billId String? @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier                @relation(fields: [supplierId], references: [id])
  lineItems    PurchaseOrderLineItem[]

  @@unique([organizationId, poNumber])
  @@index([organizationId, supplierId])
  @@index([organizationId, status])
  @@index([organizationId, issueDate])
  @@index([organizationId, expectedDate])
  @@index([organizationId, deletedAt, status, issueDate])
  @@index([supplierId])
}

model PurchaseOrderLineItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String?
  sortOrder       Int     @default(0)

  description   String
  quantity      Decimal      @db.Decimal(12, 3)
  unitPrice     Decimal      @db.Decimal(12, 2)
  unitOfMeasure String       @default("unit")
  discount      Decimal      @default(0) @db.Decimal(5, 2)
  vatTreatment  VatTreatment @default(STANDARD_RATED)
  vatRate       Decimal      @default(5) @db.Decimal(5, 2)

  subtotal  Decimal @db.Decimal(15, 2)
  vatAmount Decimal @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  receivedQty Decimal @default(0) @db.Decimal(12, 3)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

// =============================================================================
// SYSTEM: CONNECTED APPS (API keys + HMAC webhook auth)
// =============================================================================

model ConnectedApp {
  id             String @id // e.g. "app_7Bx9kQ3m" — short prefixed, globally unique
  organizationId String

  name        String
  description String?

  appSecret     String  // hex, compared with timingSafeEqual

  status AppStatus @default(ACTIVE)

  // Granular permissions: ["invoices:read", "invoices:write", "customers:read", ...]
  scopes         String[]
  // IP / URL whitelist: ["203.0.113.0/24", "example.com"] — empty = all allowed
  ipWhitelist    String[]

  lastUsedAt   DateTime?
  requestCount Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  requestLogs  ApiRequestLog[]

  @@index([organizationId])
  @@index([organizationId, status])
}

// Per-request log for external API calls — used for analytics & debugging
model ApiRequestLog {
  id    String @id @default(cuid())
  appId String

  method     String  // GET, POST, PATCH, DELETE
  path       String  // /api/ext/{appId}/invoices
  module     String  // invoices, customers, etc.
  statusCode Int     // HTTP response status
  duration   Int     // milliseconds
  ipAddress  String?
  userAgent  String?
  error      String? // error message if failed

  createdAt DateTime @default(now())

  app ConnectedApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, createdAt])
  @@index([appId, module])
  @@index([appId, statusCode])
  @@index([appId, error])
}

// =============================================================================
// SYSTEM: RATE LIMITING
// =============================================================================

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  count     Int      @default(1)
  windowStart DateTime
  expiresAt DateTime

  @@unique([key, windowStart])
  @@index([expiresAt])
}
