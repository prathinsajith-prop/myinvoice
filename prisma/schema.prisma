// =============================================================================
// myinvoice.ae — UAE E-Invoicing Platform
// Production-ready multi-tenant Prisma schema
// =============================================================================
// ARCHITECTURE: Shared database, shared schema, row-level isolation via organizationId.
// TENANCY RULE: Every tenant-scoped query MUST include organizationId.
// SOFT DELETES: Invoice/Bill/Credit|DebitNote/Customer/Supplier/Product/Expense
//               use deletedAt for FTA 5-year data retention.
// NUMBERING:    DocumentSequence ensures sequential, gapless numbering per org.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum NotificationType {
  GENERAL
  INVOICE_CREATED
  INVOICE_SENT
  INVOICE_VIEWED
  INVOICE_PAID
  INVOICE_OVERDUE
  PAYMENT_RECEIVED
  PAYMENT_REMINDER
  PAYMENT_PLAN_DUE
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  QUOTE_EXPIRED
  BILL_DUE
  CREDIT_NOTE_ISSUED
  CUSTOMER_ADDED
  TEAM_INVITE
  SUBSCRIPTION_EXPIRING
  SYSTEM_UPDATE
  SECURITY_ALERT
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum VatTreatment {
  STANDARD_RATED
  ZERO_RATED
  EXEMPT
  REVERSE_CHARGE
  OUT_OF_SCOPE
}

enum InvoiceType {
  TAX_INVOICE
  SIMPLIFIED_TAX
  PROFORMA
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CREDITED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum BillStatus {
  DRAFT
  RECEIVED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum NoteStatus {
  DRAFT
  ISSUED
  APPLIED
  VOID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CARD
  STRIPE
  PAYBY
  TABBY
  TAMARA
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum ExpenseCategory {
  RENT
  UTILITIES
  TRAVEL
  MEALS_ENTERTAINMENT
  OFFICE_SUPPLIES
  MARKETING
  SOFTWARE_SUBSCRIPTIONS
  PROFESSIONAL_FEES
  INSURANCE
  MAINTENANCE_REPAIRS
  SALARIES_WAGES
  TAX_PAYMENTS
  BANK_CHARGES
  OTHER
}

enum DocumentType {
  INVOICE
  PROFORMA
  QUOTATION
  CREDIT_NOTE
  DEBIT_NOTE
  BILL
  DELIVERY_NOTE
}

enum AddressType {
  BILLING
  SHIPPING
  OTHER
}

enum DocumentRelationType {
  QUOTATION_TO_INVOICE
  INVOICE_TO_CREDIT_NOTE
  INVOICE_TO_DEBIT_NOTE
  INVOICE_TO_DELIVERY_NOTE
  BILL_TO_PAYMENT
  INVOICE_TO_PAYMENT
}

enum AttachmentEntityType {
  INVOICE
  QUOTATION
  CREDIT_NOTE
  DEBIT_NOTE
  BILL
  EXPENSE
  CUSTOMER
  SUPPLIER
  ORGANIZATION
  DELIVERY_NOTE
}

enum DeliveryNoteStatus {
  DRAFT
  DISPATCHED
  DELIVERED
  VOID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  VIEW
  EXPORT
  SEND
  VOID
  MARK_PAID
  PRINT
  SHARE
  CONVERT
  LOGIN
  LOGOUT
  INVITE_SENT
  INVITE_ACCEPTED
  SETTINGS_CHANGE
  PASSWORD_CHANGE
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  ACCESS_DENIED
  REGENERATE_SECRET
  REVOKE
}

enum AppStatus {
  ACTIVE
  REVOKED
}

enum PdfTemplate {
  CLASSIC
  MODERN
  MINIMAL
}

// =============================================================================
// GLOBAL: AUTH  (NextAuth v5 compatible)
// =============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?

  twoFactorEnabled    Boolean  @default(false)
  twoFactorSecret     String?
  backupCodes         String[]
  passwordChangedAt   DateTime?
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  emailNotifications     Boolean @default(true)
  pushNotifications      Boolean @default(true)
  invoiceNotifications   Boolean @default(true)
  paymentNotifications   Boolean @default(true)
  reminderNotifications  Boolean @default(true)
  marketingNotifications Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMembership[]
  notifications Notification[]
  loginHistory  LoginHistory[]

  @@index([email])
  @@index([lockedUntil])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  deviceInfo   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("email")

  @@unique([identifier, token])
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  device     String?
  browser    String?
  os         String?
  city       String?
  country    String?
  success    Boolean  @default(true)
  failReason String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  title          String
  message        String
  type           NotificationType @default(GENERAL)
  entityType     String?
  entityId       String?
  actionUrl      String?
  organizationId String?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  expiresAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([userId, organizationId])
  @@index([expiresAt])
}

// =============================================================================
// GLOBAL: ORGANISATIONS
// =============================================================================

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  trn          String?
  tradeLicense String?
  legalName    String?
  businessType String?

  email   String?
  phone   String?
  website String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  emirate      String?
  country      String  @default("AE")
  postalCode   String?
  poBox        String?

  logo           String?
  primaryColor   String?
  secondaryColor String?
  pdfTemplate    PdfTemplate @default(CLASSIC)

  defaultCurrency     String  @default("AED")
  fiscalYearStart     Int     @default(1)
  invoicePrefix       String  @default("INV")
  proformaPrefix      String  @default("PI")
  quotePrefix         String  @default("QT")
  creditNotePrefix    String  @default("CN")
  debitNotePrefix     String  @default("DN")
  billPrefix          String  @default("BILL")
  expensePrefix       String  @default("EXP")
  paymentPrefix       String  @default("PAY")
  deliveryNotePrefix  String  @default("DN")
  defaultPaymentTerms Int     @default(30)
  defaultDueDateDays  Int     @default(30)
  defaultVatRate      Decimal @default(5) @db.Decimal(5, 2)
  defaultNotes        String?
  defaultTerms        String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       OrganizationMembership[]
  subscription      Subscription?
  settings          OrganizationSettings?
  customers         Customer[]
  suppliers         Supplier[]
  products          Product[]
  invoices          Invoice[]
  quotations        Quotation[]
  creditNotes       CreditNote[]
  debitNotes        DebitNote[]
  bills             Bill[]
  payments          Payment[]
  paymentsOut       PaymentOut[]
  paymentPlans      PaymentPlan[]
  expenses          Expense[]
  templates         InvoiceTemplate[]
  documentSequences DocumentSequence[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  vatReturns          VatReturn[]
  deliveryNotes       DeliveryNote[]
  documentRelations   DocumentRelation[]
  recurringInvoices   RecurringInvoice[]
  paymentReminders    PaymentReminder[]
  purchaseOrders      PurchaseOrder[]
  connectedApps       ConnectedApp[]

  @@index([slug])
  @@index([trn])
}

// =============================================================================
// GLOBAL: SUBSCRIPTIONS
// =============================================================================

model Subscription {
  id             String @id @default(cuid())
  organizationId String @unique

  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(TRIALING)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  monthlyInvoiceLimit  Int     @default(10)
  teamMemberLimit      Int     @default(1)
  storageGbLimit       Int     @default(1)
  customersLimit       Int     @default(50)
  hasApiAccess         Boolean @default(false)
  hasCustomBranding    Boolean @default(false)
  hasAdvancedReports   Boolean @default(false)
  hasMultiCurrency     Boolean @default(false)
  hasWhiteLabel        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// =============================================================================
// GLOBAL: ORGANISATION MEMBERSHIP
// =============================================================================

model OrganizationMembership {
  id             String     @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole @default(MEMBER)

  invitedEmail String?
  invitedBy    String?
  inviteToken  String?      @unique
  inviteStatus InviteStatus @default(PENDING)
  invitedAt    DateTime?
  acceptedAt   DateTime?
  expiresAt    DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([inviteToken])
  @@index([organizationId, role])
  @@index([organizationId, isActive])
  @@index([organizationId, inviteStatus])
  @@index([userId, isActive])
}

// =============================================================================
// TENANT: ORGANISATION SETTINGS
// =============================================================================

model OrganizationSettings {
  id             String @id @default(cuid())
  organizationId String @unique

  vatRegistered              Boolean   @default(false)
  vatEffectiveDate           DateTime?
  reverseChargeEnabled       Boolean   @default(false)
  simplifiedInvoiceThreshold Decimal   @default(10000) @db.Decimal(15, 2)

  showLogo        Boolean @default(true)
  showQrCode      Boolean @default(true)
  showBankDetails Boolean @default(false)
  showSignature   Boolean @default(false)
  showStamp       Boolean @default(false)
  showWatermark   Boolean @default(false)
  watermarkText   String?
  invoiceFooter   String?

  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIban          String?
  bankSwift         String?
  bankBranch        String?

  stripePublishableKey String?
  stripeSecretKeyHash  String?
  stripeWebhookSecret  String?
  paybyMerchantId      String?
  paybySecretKeyHash   String?

  emailFromName    String?
  emailFromAddress String?
  sendInvoiceCopy  Boolean @default(false)

  autoReminders      Boolean @default(true)
  reminderDaysBefore Int[]   @default([3, 7])
  reminderDaysAfter  Int[]   @default([3, 7, 14])

  lateFeeEnabled Boolean  @default(false)
  lateFeeType    String   @default("PERCENTAGE")
  lateFeeValue   Decimal? @db.Decimal(8, 2)
  lateFeeDays    Int?

  timezone     String @default("Asia/Dubai")
  dateFormat   String @default("DD/MM/YYYY")
  numberFormat String @default("en-AE")
  language     String @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// =============================================================================
// TENANT: DOCUMENT SEQUENCES
// =============================================================================

model DocumentSequence {
  id             String       @id @default(cuid())
  organizationId String
  documentType   DocumentType
  prefix         String
  nextSequence   Int          @default(1)
  padLength      Int          @default(4)
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType])
  @@index([organizationId])
}

// =============================================================================
// TENANT: CUSTOMERS
// =============================================================================

model Customer {
  id             String @id @default(cuid())
  organizationId String

  name          String
  displayName   String?
  type          String       @default("BUSINESS")
  email         String?
  phone         String?
  mobile        String?
  contactPerson String?
  website       String?
  image         String?

  trn             String?
  isVatRegistered Boolean @default(false)

  unitNumber   String?
  buildingName String?
  street       String?
  area         String?
  city         String?
  emirate      String?
  country      String  @default("AE")
  postalCode   String?
  poBox        String?

  shippingUnitNumber   String?
  shippingBuildingName String?
  shippingStreet       String?
  shippingArea         String?
  shippingCity         String?
  shippingEmirate      String?
  shippingCountry      String?
  shippingPostalCode   String?

  defaultPaymentTerms Int?
  creditLimit         Decimal?     @db.Decimal(12, 2)
  currency            String       @default("AED")
  defaultVatTreatment VatTreatment @default(STANDARD_RATED)

  totalInvoiced    Decimal  @default(0) @db.Decimal(15, 2)
  totalPaid        Decimal  @default(0) @db.Decimal(15, 2)
  totalOutstanding Decimal  @default(0) @db.Decimal(15, 2)
  invoiceCount     Int      @default(0)
  lastInvoiceDate  DateTime?

  notes String?
  tags  String[]

  portalEnabled  Boolean @default(false)
  portalToken    String? @unique
  portalPassword String?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices      Invoice[]
  quotations    Quotation[]
  creditNotes   CreditNote[]
  debitNotes    DebitNote[]
  payments      Payment[]
  deliveryNotes DeliveryNote[]
  addresses     CustomerAddress[]
  recurringInvoices RecurringInvoice[]

  @@unique([organizationId, email])
  @@index([organizationId, name])
  @@index([organizationId, trn])
  @@index([organizationId, isActive])
  @@index([organizationId, createdAt])
  @@index([portalToken])
  @@index([organizationId, deletedAt, name])
  @@index([organizationId, deletedAt, isActive])
}

// =============================================================================
// TENANT: SUPPLIERS
// =============================================================================

model Supplier {
  id             String @id @default(cuid())
  organizationId String

  name          String
  displayName   String?
  type          String  @default("BUSINESS")
  email         String?
  phone         String?
  mobile        String?
  contactPerson String?
  website       String?

  trn             String?
  isVatRegistered Boolean @default(false)

  addressLine1 String?
  addressLine2 String?
  city         String?
  emirate      String?
  country      String @default("AE")
  postalCode   String?
  poBox        String?

  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankIban            String?
  bankSwift           String?
  bankBranch          String?
  defaultPaymentTerms Int     @default(30)
  currency            String  @default("AED")

  totalBilled      Decimal  @default(0) @db.Decimal(15, 2)
  totalPaid        Decimal  @default(0) @db.Decimal(15, 2)
  totalOutstanding Decimal  @default(0) @db.Decimal(15, 2)
  billCount        Int      @default(0)
  lastBillDate     DateTime?

  notes String?
  tags  String[]

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bills           Bill[]
  paymentsOut     PaymentOut[]
  purchaseOrders  PurchaseOrder[]

  @@unique([organizationId, email])
  @@index([organizationId, name])
  @@index([organizationId, trn])
  @@index([organizationId, isActive])
  @@index([organizationId, createdAt])
  @@index([organizationId, deletedAt, name])
  @@index([organizationId, deletedAt, isActive])
}

// =============================================================================
// TENANT: PRODUCTS & SERVICES
// =============================================================================

model Product {
  id             String @id @default(cuid())
  organizationId String

  name        String
  description String?
  sku         String?
  barcode     String?

  unitPrice Decimal @db.Decimal(12, 2)
  costPrice Decimal @default(0) @db.Decimal(12, 2)
  currency  String  @default("AED")

  vatTreatment VatTreatment @default(STANDARD_RATED)
  vatRate      Decimal      @default(5) @db.Decimal(5, 2)

  type          ProductType @default(SERVICE)
  unitOfMeasure String      @default("unit")
  category      String?

  trackInventory Boolean  @default(false)
  stockQuantity  Decimal? @db.Decimal(10, 2)
  lowStockAlert  Decimal? @db.Decimal(10, 2)

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceLineItems    InvoiceLineItem[]
  quotationLineItems  QuotationLineItem[]
  creditNoteLineItems CreditNoteLineItem[]
  debitNoteLineItems  DebitNoteLineItem[]
  billLineItems       BillLineItem[]
  expenses            Expense[]
  recurringLineItems  RecurringInvoiceLineItem[]
  purchaseOrderLineItems PurchaseOrderLineItem[]

  @@unique([organizationId, sku])
  @@index([organizationId, name])
  @@index([organizationId, type])
  @@index([organizationId, category])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt, isActive, name])
}

// =============================================================================
// TENANT: QUOTATIONS
// =============================================================================

model Quotation {
  id             String @id @default(cuid())
  organizationId String
  customerId     String

  quoteNumber String
  reference   String?

  issueDate  DateTime @default(now())
  validUntil DateTime

  status QuotationStatus @default(DRAFT)

  currency     String  @default("AED")
  exchangeRate Decimal @default(1) @db.Decimal(10, 6)

  subtotal Decimal @db.Decimal(15, 2)
  totalVat Decimal @db.Decimal(15, 2)
  discount Decimal @default(0) @db.Decimal(15, 2)
  total    Decimal @db.Decimal(15, 2)

  notes         String?
  terms         String?
  internalNotes String?

  convertedAt DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer            @relation(fields: [customerId], references: [id])
  lineItems    QuotationLineItem[]
  versions     QuotationVersion[]
  invoice      Invoice?
  attachments  Attachment[]

  @@unique([organizationId, quoteNumber])
  @@index([organizationId, customerId])
  @@index([organizationId, status])
  @@index([organizationId, issueDate])
  @@index([organizationId, validUntil])
  @@index([organizationId, deletedAt, status, issueDate])
  @@index([customerId])
}

model QuotationLineItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String?
  sortOrder   Int     @default(0)

  description   String
  quantity      Decimal      @db.Decimal(12, 3)
  unitPrice     Decimal      @db.Decimal(12, 2)
  unitOfMeasure String       @default("unit")
  discount      Decimal      @default(0) @db.Decimal(5, 2)
  vatTreatment  VatTreatment @default(STANDARD_RATED)
  vatRate       Decimal      @default(5) @db.Decimal(5, 2)

  subtotal  Decimal @db.Decimal(15, 2)
  vatAmount Decimal @db.Decimal(15, 2)
  total     Decimal @db.Decimal(15, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])

  @@index([quotationId])
}

// =============================================================================
// TENANT: QUOTATION VERSIONS  (immutable snapshot per revision)
// =============================================================================

model QuotationVersion {
  id          String   @id @default(cuid())
  quotationId String
  version     Int
  snapshot    Json
  changedBy   String?
  changeNote  String?
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@unique([quotationId, version])
  @@index([quotationId])
}

// =============================================================================
// TENANT: INVOICES
// =============================================================================

model Invoice {
  id             String  @id @default(cuid())
  organizationId String
  customerId     String
  quotationId    String? @unique

  invoiceNumber String
  reference     String?
  poNumber      String?

  invoiceType InvoiceType @default(TAX_INVOICE)

  issueDate    DateTime  @default(now())
  dueDate      DateTime
  deliveryDate DateTime?

  status InvoiceStatus @default(DRAFT)

  currency     String  @default("AED")
  exchangeRate Decimal @default(1) @db.Decimal(10, 6)

  subtotal    Decimal @db.Decimal(15, 2)
  totalVat    Decimal @db.Decimal(15, 2)
  discount    Decimal @default(0) @db.Decimal(15, 2)
  total       Decimal @db.Decimal(15, 2)
  amountPaid  Decimal @default(0) @db.Decimal(15, 2)
  outstanding Decimal @db.Decimal(15, 2)

  lateFeeApplied Boolean  @default(false)
  lateFeeAmount  Decimal? @db.Decimal(12, 2)

  sellerTrn       String?
  buyerTrn        String?
  qrCodeData      String?
  ftaCompliant    Boolean @default(false)
  issuerSignature String?

  notes         String?
  terms         String?
  internalNotes String?

  sentAt    DateTime?
  viewedAt  DateTime?
  viewCount Int       @default(0)

  publicToken String? @unique

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  voidedAt   DateTime?
  voidReason String?

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer            @relation(fields: [customerId], references: [id])
  quotation     Quotation?          @relation(fields: [quotationId], references: [id])
  lineItems     InvoiceLineItem[]
  creditNotes   CreditNote[]
  debitNotes    DebitNote[]
  payments      PaymentAllocation[]
  paymentPlan   PaymentPlan?
  attachments   Attachment[]
  versions      InvoiceVersion[]
  deliveryNotes DeliveryNote[]
  paymentReminders PaymentReminder[]
  recurringSource  RecurringInvoice? @relation("RecurringSource", fields: [recurringInvoiceId], references: [id])
  recurringInvoiceId String?

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, customerId])
  @@index([organizationId, status])
  @@index([organizationId, issueDate])
  @@index([organizationId, dueDate])
  @@index([organizationId, status, dueDate])
  @@index([publicToken])
  @@index([organizationId, deletedAt, status, issueDate])
